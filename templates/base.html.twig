<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Guestbook</title>
    <style>
        :root { --primary: #007bff; --dark: #333; --light: #f4f4f4; }
        body { font-family: system-ui, -apple-system, sans-serif; line-height: 1.6; color: var(--dark); margin: 0; background: #fff; }
        
        /* Nawigacja */
        nav { background: var(--dark); padding: 1rem; display: flex; gap: 20px; justify-content: center; }
        nav a { color: white; text-decoration: none; font-weight: 500; transition: 0.3s; }
        nav a:hover { color: var(--primary); }

        /* Kontener główny */
        main { max-width: 800px; margin: 2rem auto; padding: 0 20px; min-height: 80vh; }

        /* Stopka */
        footer { text-align: center; padding: 2rem; background: var(--light); color: #777; font-size: 0.9rem; border-top: 1px solid #ddd; }

        h2 { border-bottom: 2px solid var(--primary); padding-bottom: 10px; display: inline-block; }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>
    <nav>
        <a href="{{ path('homepage') }}"> Strona główna</a>
        <a href="{{ path('about') }}"> O nas</a>
    </nav>

    <main>
        {% block body %}{% endblock %}
    </main>

    <footer>
        &copy; {{ "now"|date("Y") }} Guestbook Project • Symfony Fast Track
    </footer>

    {% block javascripts %}{% endblock %}
</body>
</html>