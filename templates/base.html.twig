<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Guestbook{% endblock %}</title>
    <style>
        :root { --primary: #007bff; --dark: #333; --light: #f4f4f4; --white: #ffffff; }
        body { font-family: system-ui, -apple-system, sans-serif; line-height: 1.6; color: var(--dark); margin: 0; background: #fff; }
        
        /* Nawigacja */
        nav { background: var(--dark); padding: 0 1rem; display: flex; gap: 20px; justify-content: center; align-items: center; height: 60px; }
        nav a, .dropbtn { color: white; text-decoration: none; font-weight: 500; transition: 0.3s; cursor: pointer; }
        nav a:hover, .dropdown:hover .dropbtn { color: var(--primary); }

        /* Dropdown Container */
        .dropdown { position: relative; display: inline-block; }

        /* Przycisk dropdowna */
        .dropbtn { background: none; border: none; font-size: inherit; font-family: inherit; padding: 10px; }

        /* Zawartość dropdowna (ukryta domyślnie) */
        .dropdown-content {
            display: none;
            position: absolute;
            background-color: var(--white);
            min-width: 200px;
            box-shadow: 0px 8px 16px 0px rgba(0,0,0,0.2);
            z-index: 1000;
            border-radius: 4px;
            top: 100%; /* pod nawigacją */
            left: 50%;
            transform: translateX(-50%);
            max-height: 300px; /* limit wysokości przy wielu konferencjach */
            overflow-y: auto;  /* scroll, jeśli lista jest długa */
        }

        /* Linki wewnątrz dropdowna */
        .dropdown-content a {
            color: var(--dark);
            padding: 12px 16px;
            display: block;
            text-align: left;
            font-size: 0.9rem;
            border-bottom: 1px solid #eee;
        }

        .dropdown-content a:last-child { border-bottom: none; }
        .dropdown-content a:hover { background-color: var(--light); color: var(--primary); }

        /* Pokaż menu po najechaniu */
        .dropdown:hover .dropdown-content { display: block; }

        /* Kontener główny */
        main { max-width: 800px; margin: 2rem auto; padding: 0 20px; min-height: 80vh; }
        footer { text-align: center; padding: 2rem; background: var(--light); color: #777; font-size: 0.9rem; border-top: 1px solid #ddd; }
        h2 { border-bottom: 2px solid var(--primary); padding-bottom: 10px; display: inline-block; }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>
    <nav>
        <a href="{{ path('homepage') }}">🏠 Strona główna</a>
        
        <div class="dropdown">
            <button class="dropbtn">Konferencje ▼</button>
            <div class="dropdown-content">
                {% for conference in conferences %}
                    <a href="{{ path('conference', {slug: conference.slug}) }}">
                        📍 {{ conference.city }} {{ conference.year }}
                    </a>
                {% endfor %}
            </div>
        </div>

        <a href="{{ path('about') }}">ℹ️ O nas</a>
    </nav>

    <main>
        {% block body %}{% endblock %}
    </main>

    <footer>
        &copy; {{ "now"|date("Y") }} Guestbook Project • Symfony Fast Track
        <br>
        <small>Odwiedziłeś tę stronę {{ app.session.get('visit_count', 1) }} razy</small>
    </footer>

    {% block javascripts %}{% endblock %}
</body>
</html>