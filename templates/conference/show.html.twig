{% extends 'base.html.twig' %}

{% block body %}
    <style>
        .comment-card { border: 1px solid #eee; padding: 1rem; border-radius: 8px; margin-bottom: 1rem; background: #f9f9f9; }
        .comment-meta { font-size: 0.85rem; color: #666; margin-bottom: 0.5rem; }
        .nav-link { display: inline-block; padding: 8px 16px; background: #007bff; color: white; border-radius: 4px; text-decoration: none; }
        .nav-link:hover { background: #0056b3; }
    </style>

    <h2>{{ conference.city }} {{ conference.year }}</h2>
    <p><strong>Liczba komentarzy:</strong> {{ comments.count }}</p>

    <div class="comments-list">
        {% for comment in comments %}
            <div class="comment-card">
                <div class="comment-meta">
                    <strong>{{ comment.author }}</strong> • {{ comment.createdAt|date('d.m.Y H:i') }}
                    <br>
                    {# DODANE POLE WEBSITE #}
                    <small>
                        Strona: 
                        {% if comment.website %}
                            <a href="{{ comment.website }}" target="_blank" rel="nofollow">{{ comment.website }}</a>
                        {% else %}
                            <span style="color: #ccc;">brak</span>
                        {% endif %}
                    </small>
                </div>
                <div class="comment-text">
                    {{ comment.text|nl2br }}
                </div>
            </div>
        {% else %}
            <p>Brak komentarzy dla tej konferencji.</p>
        {% endfor %}
    </div>

    <hr>
        <h3>Dodaj swój komentarz</h3>

        <div class="comment-form-container" style="background: #f8fafc; padding: 20px; border-radius: 8px; border: 1px solid #e2e8f0;">
            {{ form_start(comment_form) }}
                <div style="margin-bottom: 10px;">
                    {{ form_row(comment_form.author, {'label': 'Twoje imię'}) }}
                </div>
                <div style="margin-bottom: 10px;">
                    {{ form_row(comment_form.email, {'label': 'E-mail'}) }}
                </div>
                <div style="margin-bottom: 10px;">
                    {{ form_row(comment_form.website, {'label': 'Strona www (opcjonalnie)'}) }}
                </div>
                <div style="margin-bottom: 10px;">
                    {{ form_row(comment_form.text, {'label': 'Treść komentarza'}) }}
                </div>
                
                <button type="submit" class="nav-link" style="border: none; cursor: pointer;">
                    Wyślij komentarz
                </button>
            {{ form_end(comment_form) }}
        </div>
        <hr>

    <div class="navigation" style="margin-top: 2rem;">
        {% if previous >= 0 %}
            <a href="{{ path('conference', { id: conference.id, offset: previous }) }}" class="nav-link">← Poprzednie</a>
        {% endif %}

        {% if next < comments.count %}
            <a href="{{ path('conference', { id: conference.id, offset: next }) }}" class="nav-link">Następne →</a>
        {% endif %}
    </div>
{% endblock %}